# Needed locally for Phase 0 character-sheet generation (build-character-sheets.ts).
# Also needed in Replit Secrets for the runtime judge reactions and verdict.
ANTHROPIC_API_KEY=sk-ant-...

# Needed in Replit Secrets for the runtime embedding (reembed-with-openai.ts +
# the per-query embed in artifacts/web/lib/retrieval.ts). NOT required locally —
# Ollama (below) handled the original local embeddings; runtime uses OpenAI.
# Add this to Replit's Secrets tab, not to your local .env.
OPENAI_API_KEY=sk-...

# Optional, local only — used by scripts/embed-chunks.ts to generate the
# historical Ollama embeddings in data/chunks/ (NOT used by the deployed app).
# Defaults to http://localhost:11434 if unset.
# OLLAMA_HOST=http://localhost:11434
